---
// Override: render Starlight's default social links (GitHub, etc.) and
// append a NeuralSeek link that points to neuralseek.com. Because this
// replaces the SocialIcons component, the NeuralSeek icon appears
// everywhere the social icons render (desktop header + mobile sidebar).
import Default from '@astrojs/starlight/components/SocialIcons.astro';
import nsMark from '../assets/neuraldocs-icon.png';
---

<Default />
<a href="https://neuralseek.com" rel="me" class="ns-social sl-flex">
	<span class="sr-only">NeuralSeek</span>
	<span class="ns-mark" aria-hidden="true" style={`--ns-mark: url(${nsMark.src})`}></span>
</a>

<style>
	/* Mirrors Starlight's own SocialIcons anchor rule so this link sizes,
	   colors, and hovers identically to the icons it sits next to. */
	.ns-social {
		color: var(--sl-color-text-accent);
		padding: 0.5em;
		margin: -0.5em;
	}
	.ns-social:hover {
		opacity: 0.66;
	}
	/* The brand mark only ships as a gradient PNG. Mask it so just its alpha
	   channel is used and the glyph paints in currentColor, matching the
	   theme's monochrome SVG icons. 1em box = Starlight's Icon.astro sizing. */
	.ns-mark {
		width: 1em;
		height: 1em;
		background-color: currentColor;
		-webkit-mask: var(--ns-mark) center / contain no-repeat;
		mask: var(--ns-mark) center / contain no-repeat;
	}
</style>
