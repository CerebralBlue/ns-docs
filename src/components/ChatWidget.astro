---
// Frontend-only "Ask AI" chat widget: a floating launcher button that toggles
// a chat panel open/closed, with a message list + input. This is UI only —
// there is no backend wired up. The submit handler echoes a placeholder reply
// so the interaction is visible. To make it real, replace the body of
// `sendMessage()` in the inline script with a fetch to the NeuralSeek
// `/api/*` proxy (browser-safe embedcode, never the admin key).
//
// Icons come from Starlight's built-in set so they inherit currentColor and
// stay crisp at any DPR — no image assets involved. The sparkle is a local
// inline path (Starlight's set has no sparkle) and follows the same rules.
import { Icon } from '@astrojs/starlight/components';
---

<div class="ns-chat" data-ns-chat>
	<!-- Launcher: hides while the panel is open, and the panel takes over this
	     exact spot. Icon-only, so the accessible name lives on aria-label and
	     the sighted affordance is the hover/focus tooltip (::after). -->
	<button
		type="button"
		class="ns-chat__launcher"
		data-ns-toggle
		aria-expanded="false"
		aria-controls="ns-chat-panel"
		aria-label="Ask AI"
	>
		<svg
			class="ns-chat__sparkle"
			viewBox="0 0 24 24"
			fill="currentColor"
			aria-hidden="true"
			focusable="false"
		>
			<path
				d="M11 3.5l1.55 4.4a3.2 3.2 0 0 0 2.05 2.05L19 11.5l-4.4 1.55a3.2 3.2 0 0 0-2.05 2.05L11 19.5l-1.55-4.4a3.2 3.2 0 0 0-2.05-2.05L3 11.5l4.4-1.55A3.2 3.2 0 0 0 9.45 7.9L11 3.5z"
			></path>
			<path
				d="M18.5 15l.6 1.7a1.3 1.3 0 0 0 .8.8l1.7.6-1.7.6a1.3 1.3 0 0 0-.8.8l-.6 1.7-.6-1.7a1.3 1.3 0 0 0-.8-.8L15.4 18.1l1.7-.6a1.3 1.3 0 0 0 .8-.8L18.5 15z"
			></path>
		</svg>
	</button>

	<!-- Panel -->
	<div
		class="ns-chat__modal"
		id="ns-chat-panel"
		data-ns-modal
		hidden
		role="dialog"
		aria-label="Ask AI"
	>
		<header class="ns-chat__header">
			<div class="ns-chat__title">
				<span class="ns-chat__dot"></span>
				Ask AI
			</div>
			<button type="button" class="ns-chat__close" data-ns-close aria-label="Close chat">
				<Icon name="close" size="1.125rem" />
			</button>
		</header>

		<div class="ns-chat__log" data-ns-log>
			<div class="ns-chat__msg ns-chat__msg--bot">
				Hi! Ask me anything about the docs.
			</div>
		</div>

		<form class="ns-chat__form" data-ns-form>
			<input
				type="text"
				class="ns-chat__input"
				data-ns-input
				placeholder="Ask a question…"
				autocomplete="off"
				aria-label="Your question"
			/>
			<button type="submit" class="ns-chat__send" aria-label="Send">
				<Icon name="right-arrow" size="1.125rem" />
			</button>
		</form>
	</div>
</div>

<style>
	.ns-chat {
		--ns-chat-w: 380px;
		--ns-chat-h: 560px;
		--ns-chat-launcher-size: 3.5rem;
		--ns-chat-inset: 1.5rem;
	}

	/* Launcher: round, icon-only. Shares the same corner inset as the panel,
	   so the panel appears exactly where this button was. */
	.ns-chat__launcher {
		position: fixed;
		right: var(--ns-chat-inset);
		bottom: var(--ns-chat-inset);
		z-index: 100;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: var(--ns-chat-launcher-size);
		height: var(--ns-chat-launcher-size);
		padding: 0;
		border: none;
		border-radius: 50%;
		background: var(--sl-color-text-accent);
		color: var(--sl-color-black);
		cursor: pointer;
		box-shadow: 0 6px 20px rgba(0, 0, 0, 0.25);
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.ns-chat__launcher:hover {
		transform: translateY(-2px);
		box-shadow: 0 10px 28px rgba(0, 0, 0, 0.3);
	}
	.ns-chat__launcher:focus-visible {
		outline: 2px solid var(--sl-color-white);
		outline-offset: 3px;
	}
	/* Open state: the panel occupies this corner, so the launcher steps aside.
	   Focus is moved into the panel first — see setOpen() in the script. */
	.ns-chat[data-open] .ns-chat__launcher {
		display: none;
	}

	.ns-chat__sparkle {
		width: 1.5rem;
		height: 1.5rem;
	}

	/* Tooltip — the icon-only launcher's visible affordance. aria-label carries
	   the same wording for screen readers, so this stays decorative. */
	.ns-chat__launcher::after {
		content: 'Ask AI';
		position: absolute;
		right: calc(100% + 0.65rem);
		top: 50%;
		translate: 0 -50%;
		padding: 0.35rem 0.6rem;
		border-radius: 6px;
		background: var(--sl-color-gray-6);
		color: var(--sl-color-white);
		border: 1px solid var(--sl-color-hairline);
		font-size: var(--sl-text-xs);
		font-weight: 600;
		white-space: nowrap;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.15s ease;
	}
	.ns-chat__launcher:hover::after,
	.ns-chat__launcher:focus-visible::after {
		opacity: 1;
	}

	/* Panel: pinned to the same corner the launcher occupies. */
	.ns-chat__modal {
		position: fixed;
		right: var(--ns-chat-inset);
		bottom: var(--ns-chat-inset);
		z-index: 101;
		display: flex;
		flex-direction: column;
		width: min(var(--ns-chat-w), calc(100vw - 2rem));
		height: min(var(--ns-chat-h), calc(100vh - var(--ns-chat-inset) * 2));
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-hairline);
		border-radius: 14px;
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
		overflow: hidden;
		transform-origin: bottom right;
		animation: ns-chat-in 0.18s ease;
	}

	/* `display: flex` above would otherwise beat the UA's [hidden] rule (author
	   styles win at equal specificity), leaving the panel permanently open. */
	.ns-chat__modal[hidden] {
		display: none;
	}
	/* Grows out of the launcher's corner rather than sliding in from nowhere. */
	@keyframes ns-chat-in {
		from { opacity: 0; scale: 0.9; }
		to   { opacity: 1; scale: 1; }
	}
	@media (prefers-reduced-motion: reduce) {
		.ns-chat__modal {
			animation: none;
		}
		.ns-chat__launcher {
			transition: none;
		}
		.ns-chat__launcher:hover {
			transform: none;
		}
	}

	.ns-chat__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.9rem 1rem;
		border-bottom: 1px solid var(--sl-color-hairline);
		background: var(--sl-color-bg-nav);
	}
	.ns-chat__title {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-weight: 600;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-white);
	}
	.ns-chat__dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--sl-color-text-accent);
	}
	.ns-chat__close {
		display: inline-flex;
		padding: 0.25rem;
		border: none;
		background: transparent;
		color: var(--sl-color-gray-2);
		cursor: pointer;
		border-radius: 6px;
	}
	.ns-chat__close:hover {
		color: var(--sl-color-white);
		background: var(--sl-color-gray-6);
	}

	/* Message log */
	.ns-chat__log {
		flex: 1;
		overflow-y: auto;
		padding: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.ns-chat__msg {
		max-width: 85%;
		padding: 0.6rem 0.8rem;
		border-radius: 12px;
		font-size: var(--sl-text-sm);
		line-height: 1.5;
		white-space: pre-wrap;
		word-wrap: break-word;
	}
	.ns-chat__msg--bot {
		align-self: flex-start;
		background: var(--sl-color-gray-6);
		color: var(--sl-color-white);
		border-bottom-left-radius: 4px;
	}
	.ns-chat__msg--user {
		align-self: flex-end;
		background: var(--sl-color-text-accent);
		color: var(--sl-color-black);
		border-bottom-right-radius: 4px;
	}
	.ns-chat__msg--typing {
		color: var(--sl-color-gray-3);
		font-style: italic;
	}

	/* Input */
	.ns-chat__form {
		display: flex;
		gap: 0.5rem;
		padding: 0.75rem;
		border-top: 1px solid var(--sl-color-hairline);
	}
	.ns-chat__input {
		flex: 1;
		padding: 0.6rem 0.8rem;
		border: 1px solid var(--sl-color-hairline);
		border-radius: 8px;
		background: var(--sl-color-bg);
		color: var(--sl-color-white);
		font-size: var(--sl-text-sm);
	}
	.ns-chat__input:focus {
		outline: none;
		border-color: var(--sl-color-text-accent);
	}
	.ns-chat__send {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		border: none;
		border-radius: 8px;
		background: var(--sl-color-text-accent);
		color: var(--sl-color-black);
		cursor: pointer;
	}
	.ns-chat__send:hover {
		opacity: 0.9;
	}

	@media (max-width: 30rem) {
		.ns-chat {
			--ns-chat-inset: 1rem;
		}
	}
</style>

<script>
	function initChat() {
		const root = document.querySelector('[data-ns-chat]');
		if (!root || root.hasAttribute('data-ns-init')) return;
		root.setAttribute('data-ns-init', '');

		const modal = root.querySelector('[data-ns-modal]') as HTMLElement;
		const log = root.querySelector('[data-ns-log]') as HTMLElement;
		const form = root.querySelector('[data-ns-form]') as HTMLFormElement;
		const input = root.querySelector('[data-ns-input]') as HTMLInputElement;
		const toggleBtn = root.querySelector('[data-ns-toggle]') as HTMLButtonElement;

		const isOpen = () => root.hasAttribute('data-open');

		// restoreFocus: only when the user deliberately closed it (button/Esc).
		// Clicking away must not yank focus back to the launcher.
		//
		// Order matters here. Opening hides the launcher via [data-open] while it
		// still holds focus, which would drop focus to <body>; moving focus into
		// the input immediately after keeps the keyboard path intact. Closing
		// un-hides the launcher before focusing it — .focus() is a no-op on a
		// display:none element.
		const setOpen = (open: boolean, restoreFocus = true) => {
			modal.hidden = !open;
			root.toggleAttribute('data-open', open);
			toggleBtn.setAttribute('aria-expanded', String(open));
			if (open) input.focus();
			else if (restoreFocus) toggleBtn.focus();
		};

		// The launcher only opens now — it's hidden while the panel is up, and
		// the panel's own close button (and Esc) brings it back.
		toggleBtn.addEventListener('click', () => setOpen(!isOpen()));
		root.querySelector('[data-ns-close]')?.addEventListener('click', () => setOpen(false));

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && isOpen()) setOpen(false);
		});

		// Click outside the widget closes it, without stealing focus.
		document.addEventListener('click', (e) => {
			if (isOpen() && !root.contains(e.target as Node)) setOpen(false, false);
		});

		function addMessage(text: string, who: 'user' | 'bot', extraClass = '') {
			const el = document.createElement('div');
			el.className = `ns-chat__msg ns-chat__msg--${who} ${extraClass}`.trim();
			el.textContent = text;
			log.appendChild(el);
			log.scrollTop = log.scrollHeight;
			return el;
		}

		// Frontend-only stub. Replace this with a fetch to the NeuralSeek
		// `/api/*` proxy to wire up real answers.
		async function sendMessage(question: string) {
			const typing = addMessage('Thinking…', 'bot', 'ns-chat__msg--typing');
			await new Promise((r) => setTimeout(r, 600));
			typing.remove();
			addMessage(
				'This is a frontend-only demo. Connect me to a backend to get real answers.',
				'bot'
			);
		}

		form.addEventListener('submit', (e) => {
			e.preventDefault();
			const q = input.value.trim();
			if (!q) return;
			addMessage(q, 'user');
			input.value = '';
			sendMessage(q);
		});
	}

	// Run on first load and on Starlight's client-side view transitions.
	initChat();
	document.addEventListener('astro:page-load', initChat);
</script>
